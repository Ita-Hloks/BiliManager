{
  "name": "bili-filter-extension",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "node scripts/prepareHtml.mjs \u0026\u0026 vite build \u0026\u0026 vite build --config vite.content.config.ts \u0026\u0026 node scripts/validateContentBuild.mjs \u0026\u0026 node scripts/copyManifest.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier \"**/*.{ts,tsx,js,jsx,json,css,md,html,mjs,cjs,yml,yaml}\" --write",
    "format:check": "prettier \"**/*.{ts,tsx,js,jsx,json,css,md,html,mjs,cjs,yml,yaml}\" --check",
    "check": "npm run typecheck \u0026\u0026 npm run lint \u0026\u0026 npm run format:check",
    "guard:branch": "node scripts/guardBranch.mjs",
    "precommit": "npm run guard:branch \u0026\u0026 lint-staged \u0026\u0026 npm run typecheck \u0026\u0026 npm run format:check",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md,html}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@types/chrome": "^0.0.287",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "lucide-react": "^0.468.0",
    "postcss": "^8.4.49",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@eslint-react/eslint-plugin": "^5.10.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "typescript-eslint": "^8.62.1"
  }
}
