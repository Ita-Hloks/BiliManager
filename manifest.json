{
  "manifest_version": 3,
  "name": "BiliManager",
  "description": "面向哔哩哔哩的本地管理与浏览体验优化扩展",
  "version": "0.1.0",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "BiliManager",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "permissions": ["storage"],
  "host_permissions": ["https://*.bilibili.com/*", "https://search.bilibili.com/*"],
  "content_scripts": [
    {
      "matches": ["https://*.bilibili.com/*", "https://search.bilibili.com/*"],
      "js": ["assets/content.js"],
      "css": ["assets/content.css"],
      "run_at": "document_idle"
    }
  ]
}
